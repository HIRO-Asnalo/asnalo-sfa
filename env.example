# ============================================================
# Brave Search API（新規開拓AI のリアルタイムWeb検索）
# https://api.search.brave.com/ で無料プラン取得（2000回/月）
# 未設定でも動作するが、Claude学習データのみになる
# ============================================================
BRAVE_API_KEY=BSA_xxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Google Sheets API（サービスアカウント）
# Google Cloud Console でサービスアカウントを作成し、
# JSONキーをダウンロード後、1行に圧縮してここに貼る
# ============================================================
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT",...}

# スプレッドシートID（URLの /d/ 以降の文字列）
SPREADSHEET_ID=your_google_spreadsheet_id_here

# ============================================================
# Resend API（ステップメール送信）
# https://resend.com でアカウント作成・APIキー取得
# ============================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=info@asnalo.com
FROM_NAME=株式会社アスナロ

# ============================================================
# Slack 通知
# ============================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
